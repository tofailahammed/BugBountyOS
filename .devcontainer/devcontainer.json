{
  "name": "BugBountyOS",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "ms-python.python",
        "github.vscode-github-actions",
        "redhat.java",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  }
}  
